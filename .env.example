# ============================================================
#  LUMEN FILMES — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha com suas chaves.
#  NUNCA commite o arquivo .env com chaves reais!
# ============================================================

# --- TMDB (The Movie Database) ---
# Obtenha em: https://www.themoviedb.org/settings/api
# Use o "API Read Access Token" (Bearer Token — começa com "eyJ...")
# Importante: Requer o prefixo VITE_ pois a API é chamada pelo navegador do usuário.
VITE_TMDB_API_KEY=

# --- OpenAI ---
# Obtenha em: https://platform.openai.com/api-keys
# Usada exclusivamente no servidor (não fica exposta no browser)
OPENAI_API_KEY=

# ============================================================
#  VERCEL: adicione essas variáveis em:
#  Settings > Environment Variables
#  - VITE_TMDB_API_KEY (Exposta ao navegador)
#  - OPENAI_API_KEY (Server-side only)
# ============================================================
